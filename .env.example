# Deriva Companion Webapp — environment variable surface.
#
# Copy this file to `.env.local` for local development and fill in real values.
# In production, set these on Vercel's Project → Settings → Environment Variables.
# NEVER commit a real .env or .env.production — the `.gitignore` excludes every
# .env* except this example.

# ─────────────────────────────────────────────────────────────────────────────
# Backend — Cloud Run service hosting the Go API.
# Used by the openapi-fetch client (src/api/hooks.ts) and woven into the CSP
# `connect-src` header by middleware.ts. Required in production.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://YOUR-CLOUD-RUN-SERVICE.run.app

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Authentication — client config.
# These are public keys (safe to ship to the browser). The matching server-side
# secret (service account) lives only on the Go backend, not here.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT-ID.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR-PROJECT-ID
NEXT_PUBLIC_FIREBASE_APP_ID=

# Local-dev only: when true, the client connects to the Firebase Auth emulator
# at NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST. Leave unset (or "false") in
# production. The emulator-host swap also handles LAN devices automatically
# (see src/auth/firebase.ts → resolveEmulatorHost).
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=false
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=http://localhost:9099

# ─────────────────────────────────────────────────────────────────────────────
# Mock Service Worker — local dev only.
# Default is enabled in development (`process.env.NODE_ENV === "development"`)
# and auto-disabled in production. Set to "false" locally when you want the
# real Go backend instead of fixtures.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_USE_MSW=true

# ─────────────────────────────────────────────────────────────────────────────
# Sentry — error monitoring + Performance.
# DSN is public; SENTRY_AUTH_TOKEN is a secret used at build time for
# sourcemap upload (never read at runtime, never sent to the browser).
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=deriva
SENTRY_PROJECT=companion-web

# ─────────────────────────────────────────────────────────────────────────────
# Resend — transactional email + audiences.
# Used by `scripts/send-test-apertura.ts`, `scripts/build-emails.ts`, and the
# waitlist server action (src/server/waitlist.ts), which creates the contact +
# sends the welcome email synchronously on signup.
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Apertura first-cup audience.
RESEND_AUDIENCE_ID=
# Companion app teaser — dedicated interest-list audience (campaign="companion").
RESEND_COMPANION_AUDIENCE_ID=
RESEND_FROM_EMAIL=hola@derivastudio.cl
RESEND_FROM_NAME=Deriva Coffee Studio
RESEND_UNSUBSCRIBE_URL=https://derivastudio.cl/unsubscribe

# ─────────────────────────────────────────────────────────────────────────────
# Campaign-codes send pipeline (scripts/send-apertura-codes.ts and any future
# campaign send script). NOT consumed by the runtime webapp — Node-only.
#
# BACKEND_API_BASE_URL: direct Cloud Run host. NEXT_PUBLIC_API_BASE_URL is
#   "/api" for the browser (Next.js rewrite path) and can't be used by a
#   Node script — the script needs the full host. Get the current value from
#   Vercel Production env (NEXT_PUBLIC_API_BASE_URL), or use the Cloud Run
#   hostname directly. Changes on backend redeploy.
#
# BACKEND_ADMIN_TOKEN: fresh Firebase ID token for an owner/manager user.
#   Tokens expire ~1h — re-obtain right before running the send. See
#   docs/email/apertura-send-runbook.md §2 for the dev-tools copy procedure.
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_API_BASE_URL=https://YOUR-CLOUD-RUN-SERVICE.run.app
BACKEND_ADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Dev-only conveniences. None of these are needed in production.
# ─────────────────────────────────────────────────────────────────────────────
# Where `next dev` rewrites `/api/*` for the in-browser dev proxy. Lets phones
# on the LAN hit the dev backend without knowing the Mac's IP.
DERIVA_BACKEND_PROXY_URL=http://localhost:8080

# Feature flag — show or hide price strings on the carta. Default = visible.
DERIVA_SHOW_PRICES=true

# ─────────────────────────────────────────────────────────────────────────────
# Deriva Match Up — shared staff passcode for the PIN-gated counter tool at
# staff.derivastudio.cl/match-up. Required in production for the staff form to
# unlock; if unset, the tool stays locked. Rotate via Vercel env. Server-only.
# ─────────────────────────────────────────────────────────────────────────────
MATCH_UP_STAFF_PIN=

# ─────────────────────────────────────────────────────────────────────────────
# Photo CDN — overrides the base URL used by DerivaImage to fetch responsive
# variants. Defaults to the prod CDN (https://media.derivastudio.cl/v1) from
# src/data/photos.ts. Set to /photos for offline review when public/photos/ is
# present and DNS for media.derivastudio.cl isn't live yet.
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_PHOTO_BASE_URL=/photos/v1

# ─────────────────────────────────────────────────────────────────────────────
# Staff campaign-reward redemptions — server-held bearer for protected
# /staff/* endpoints. Long-lived staff/manager/owner-role token. Server-only
# — never NEXT_PUBLIC. Until this is set, the redemptions tool shows a calm
# "config unavailable" state instead of a raw 401.
# ─────────────────────────────────────────────────────────────────────────────
# Server-held bearer for protected /staff/* campaign-reward endpoints.
# Long-lived staff/manager/owner-role token. Server-only — never NEXT_PUBLIC.
BACKEND_STAFF_TOKEN=
