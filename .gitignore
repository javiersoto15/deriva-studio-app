# Dependencies
node_modules/

# Build artifacts
.next/
apps/web/.next/
out/
dist/

# OS
.DS_Store

# Logs
*.log

# Vercel
.vercel

# Environment variables — NEVER commit any .env file. Vercel's dashboard is
# the source of truth in production; .env.local is the developer's machine
# only. Document the variable surface in .env.example instead.
.env
.env.*
!.env.example

# Sentry sourcemap config
.sentryclirc

# Editor / IDE
.idea/
.vscode/
.worktrees/
*.swp

# Generated email templates (rebuilt by npm run email:build)
public/email-builds/

# Service worker artifacts (regenerated by build)
public/sw.js
public/sw.js.map
public/swe-worker-development.js
tsconfig.tsbuildinfo
/public/photos/
tmp/

# Capacitor native projects — generated by `npx cap add ios|android`.
# We commit capacitor.config.ts (the source of truth) and the project shells,
# but ignore build outputs + machine-specific Xcode/Gradle caches.
ios/App/build/
ios/App/Pods/
ios/App/Podfile.lock
ios/DerivedData/
ios/.xcode.env.local
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/captures/
android/.idea/
android/app/release/
*.jks
*.keystore
!debug.keystore
