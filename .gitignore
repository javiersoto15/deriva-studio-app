# Dependencies
node_modules/

# Build artifacts
.next/
apps/web/.next/
out/
dist/

# OS
.DS_Store

# Logs
*.log

# Vercel
.vercel

# Environment variables — NEVER commit any .env file. Vercel's dashboard is
# the source of truth in production; .env.local is the developer's machine
# only. Document the variable surface in .env.example instead.
.env
.env.*
!.env.example

# Sentry sourcemap config
.sentryclirc

# Editor / IDE
.idea/
.vscode/
*.swp

# Generated email templates (rebuilt by npm run email:build)
public/email-builds/

# Service worker artifacts (regenerated by build)
public/sw.js
public/sw.js.map
public/swe-worker-development.js
