{
  "name": "deriva-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:emulator": "NEXT_PUBLIC_FIREBASE_USE_EMULATOR=true next dev -H 0.0.0.0",
    "dev:fresh": "lsof -ti:3000 -ti:3001 -ti:3002 | xargs -r kill -9 2>/dev/null; rm -rf .next && next dev",
    "dev:reset": "lsof -ti:3000 -ti:3001 -ti:3002 | xargs -r kill -9 2>/dev/null; rm -rf .next node_modules/.cache && next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "email:build": "tsx scripts/build-emails.ts",
    "email:test-send": "tsx scripts/send-test-apertura.ts",
    "send:apertura": "tsx scripts/send-apertura-codes.ts",
    "send:apertura:dry": "tsx scripts/send-apertura-codes.ts --dry-run",
    "send:apertura:agent": "bash scripts/with-admin-token.sh tsx scripts/send-apertura-codes.ts",
    "send:apertura:agent:dry": "bash scripts/with-admin-token.sh tsx scripts/send-apertura-codes.ts --dry-run",
    "send:apertura-reminder": "tsx scripts/send-apertura-reminder.ts",
    "send:apertura-reminder:dry": "tsx scripts/send-apertura-reminder.ts --dry-run",
    "send:apertura-reminder:agent": "bash scripts/with-admin-token.sh tsx scripts/send-apertura-reminder.ts",
    "send:apertura-reminder:agent:dry": "bash scripts/with-admin-token.sh tsx scripts/send-apertura-reminder.ts --dry-run",
    "photos:upload": "tsx scripts/upload-photos.ts",
    "api:types": "openapi-typescript ../13_companion_backend/docs/openapi.yaml -o src/api/schema.ts",
    "msw:init": "msw init public/ --save",
    "firebase:emulator": "firebase emulators:start --only auth --project deriva-studio-production"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sentry/nextjs": "^10.52.0",
    "@serwist/next": "^9.5.11",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "flag-icons": "^7.5.0",
    "msw": "^2.14.5",
    "next": "16.2.4",
    "next-intl": "^4.11.1",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "resend": "^6.12.2",
    "serwist": "^9.5.11",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "png-to-ico": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
